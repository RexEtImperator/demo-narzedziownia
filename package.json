{
  "name": "system-zarzadzania-narzedziownia-frontend",
  "version": "1.0.0",
  "description": "Frontend dla systemu zarządzania narzędziownią",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "vite",
    "start:https": "set HTTPS=true&&vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node scripts/run-vitest.cjs",
    "test:ci": "vitest --run --passWithNoTests",
    "server": "set PORT=3000 && node backend/server.js",
    "dev": "concurrently \"npm run server\" \"npm start\"",
    "dev:https": "concurrently \"npm run server\" \"npm run start:https\"",
    "i18n:diff": "node scripts/report_translation_diff.cjs",
    "i18n:sync": "node scripts/sync_translations_from_files.cjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "node -e \"console.log('Brak TypeScript/prop-types — pomijam typecheck')\""
  },
  "keywords": [],
  "author": "dbrzezinsky",
  "license": "MIT",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/react-query": "^5.90.16",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dompurify": "^3.3.1",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.0",
    "flowbite": "^4.0.1",
    "framer-motion": "^12.26.1",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^2.0.9",
    "ipp": "^1.1.0",
    "jsbarcode": "^3.12.1",
    "jsdom": "^24.0.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "pm2": "^6.0.14",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-barcode-generator": "^1.0.0",
    "react-dom": "^18.2.0",
    "react-qr-barcode-scanner": "^2.1.15",
    "react-router-dom": "^6.30.2",
    "react-toastify": "^11.0.5",
    "react-window": "^1.8.11",
    "recharts": "^2.15.4",
    "sqlite3": "^5.1.7",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.19",
    "baseline-browser-mapping": "^2.9.18",
    "concurrently": "^7.6.0",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.4.47",
    "supabase": "^2.75.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=9"
  }
