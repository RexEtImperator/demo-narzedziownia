# DODAJ ZMIENNE DO PLIKU backend/.env
#NODE_ENV=development
PORT=3000
JWT_SECRET=secret_code

# SMTP configuration for sending emails
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:8082,http://127.0.0.1:8082,http://localhost:3000,http://localhost:3001

# SSL Config
SSL_CRT_FILE=
SSL_KEY_FILE=
RESTART_DELAY=0

# push notification config
# generowanie kluczy poprzez komende npx web-push generate-vapid-keys i wklej do .env
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost